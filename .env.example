# Heard — example environment variables (BYOK for self-hosters)
#
# Copy to `.env` and fill in your own keys, OR set these in your shell.
# None of these are required to run the packaged app — you can also
# configure keys from the menu bar (Settings -> Keys) or via
# `heard config set <key> <value>`, which takes precedence over env vars.
# The packaged .app does NOT read your shell env, so use the menu / CLI
# there; env vars are for running from source.

# --- Narration brain (LLM) — bring your own key -------------------------

# Anthropic API key. Used for the narration brain (Claude Haiku) on the
# BYOK path, bypassing the managed api.heard.dev proxy.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional OpenAI API key. Alternate narration provider on the BYOK path.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the narration-brain model on the BYOK path only
# (e.g. claude-sonnet-5). Empty/unset -> the default Haiku checkpoint.
# HEARD_BRAIN_MODEL=

# --- Text-to-speech (TTS) — bring your own key --------------------------

# NOTE: the ElevenLabs key is NOT read from the environment. Set it via
# the menu (Settings -> Keys) or `heard config set elevenlabs_api_key <key>`.
# Without a key, signed-in users use the managed voice proxy, or you can
# download the local Kokoro voice for fully-offline TTS.
# ELEVENLABS_API_KEY=  (configured in-app, not via env)

# --- Operational / debug (optional) -------------------------------------

# Set to 1 to enable verbose daemon debug logging.
# HEARD_DEBUG=1

# Set to 1 to disable the hook subprocess (used internally to avoid
# recursive narration when the daemon shells out to the CLI). You
# generally do not need to set this yourself.
# HEARD_HOOK_DISABLED=1
