<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- py2app bundles Python.framework + libcrypto/libssl/libffi
         that are signed by Apple (or upstream), not by our Developer
         ID. Hardened-runtime's strict library validation rejects
         binaries that chain to a different identity than the host,
         crashing the app at launch. Disabling library validation lets
         the bundled Python framework load nested .dylibs the loader
         sees as "third-party". -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- packaging/app_entry.py sets SSL_CERT_FILE / REQUESTS_CA_BUNDLE
         before any HTTPS-using import (the frozen Python in the bundle
         has no system CA path). Hardened runtime blocks DYLD_* and
         related env-var manipulation by default; this re-allows the
         narrow set we actually use for bootstrapping. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Heard Power's voice service (the bundled `python -m heard_power serve`)
         opens the microphone for dictation. Under the hardened runtime, macOS
         DENIES mic access outright — with NO TCC prompt — unless the binary
         carries this entitlement. Without it the serve is killed the instant it
         touches the mic (a silent native crash → crash-loop → PTT never works),
         and it only appeared to work in unsigned dev builds where the runtime
         doesn't enforce entitlements. NSMicrophoneUsageDescription (Info.plist)
         supplies the prompt text; this entitlement is what actually allows it. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Heard Power's STT pipeline pulls in numba/llvmlite (via librosa), which
         JIT-compiles to executable memory at runtime. Under the hardened
         runtime macOS KILLS the process the instant it hits an unsigned
         executable page — SIGKILL "Code Signature Invalid / Invalid Page",
         crashing in libllvmlite.dylib ~2s after the serve goes ready. These two
         entitlements permit JIT / unsigned executable memory so numba can run.
         (This was the real PTT-never-worked crash; unsigned dev builds don't
         enforce it.) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
